# Environment Variables
# This file serves as a template for environment configuration
# Copy this file to .env.local and fill in with actual values

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Application Environment
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG_MODE=false

# Third-party Services (if needed)
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=

# Music/Audio Settings
VITE_AUDIO_ENABLE_HLS=true
VITE_AUDIO_CROSSORIGIN=anonymous

# Deployment
VITE_PUBLIC_URL=/
